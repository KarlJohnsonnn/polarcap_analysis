#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOST="127.0.0.1"
PORT="8000"
BASE_URL="http://${HOST}:${PORT}"
STATUS_URL="${BASE_URL}/__quicklookbrowser/status"
APP_URL="${BASE_URL}/web/cs_data_viewer/cosmo-viewer.html"
LOG_FILE="${TMPDIR:-/tmp}/quicklookbrowser-server.log"

server_ready() {
  curl -fsS "${STATUS_URL}" >/dev/null 2>&1
}

open_url() {
  if command -v open >/dev/null 2>&1; then
    open "${APP_URL}" >/dev/null 2>&1 || true
    return
  fi
  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "${APP_URL}" >/dev/null 2>&1 || true
    return
  fi
  printf 'QuicklookBrowser URL: %s\n' "${APP_URL}"
}

if ! server_ready; then
  nohup python3 "${ROOT_DIR}/web/cs_data_viewer/serve_quicklookbrowser.py" \
    --host "${HOST}" \
    --port "${PORT}" \
    --repo-root "${ROOT_DIR}" \
    >"${LOG_FILE}" 2>&1 &

  for _ in {1..50}; do
    if server_ready; then
      break
    fi
    sleep 0.2
  done
fi

if ! server_ready; then
  printf 'QuicklookBrowser server did not start. Check %s\n' "${LOG_FILE}" >&2
  exit 1
fi

open_url
printf 'QuicklookBrowser ready: %s\n' "${APP_URL}"
